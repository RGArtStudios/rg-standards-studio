{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "jsx":              "preserve",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "paths":            { "@/*": ["./src/*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
