{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "moduleResolution": "node",
    "strict":           true,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "outDir":           "./dist",
    "rootDir":          "./src",
    "skipLibCheck":     true,
    "inlineSourceMap":  true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
