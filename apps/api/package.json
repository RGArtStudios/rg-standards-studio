{
  "name": "@rg/standards-studio-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":         "ts-node-dev --respawn --transpile-only src/index.ts",
    "build":       "tsc",
    "start":       "node dist/index.js",
    "db:migrate":  "prisma migrate deploy",
    "db:seed":     "prisma db seed",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@octokit/rest":      "^20.0.0",
    "@prisma/client":     "^5.0.0",
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "express":            "^4.18.0",
    "helmet":             "^7.0.0",
    "jsonwebtoken":       "^9.0.0",
    "source-map-support": "^0.5.21",
    "zod":                "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs":     "^2.4.6",
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node":         "^20.0.0",
    "prisma":              "^5.0.0",
    "ts-node":             "^10.9.2",
    "ts-node-dev":         "^2.0.0",
    "typescript":          "^5.4.0"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma",
    "seed": "ts-node ../../prisma/seed.ts"
  }
}
