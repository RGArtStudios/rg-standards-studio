{
  "name": "rg-standards-studio",
  "version": "1.0.0",
  "private": true,
  "description": "Rainier Gardens Standards Definition and Certification Studio",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm --workspace=apps/api run dev",
    "dev:web": "npm --workspace=apps/web run dev",
    "build": "npm --workspace=apps/api run build && npm --workspace=apps/web run build",
    "db:migrate": "npm --workspace=apps/api run db:migrate",
    "db:seed": "npm --workspace=apps/api run db:seed"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
